        name = parts[0]
        version = parts[1] if len(parts) > 1 else ""
        source = "aur/local" if name in foreign_names else "pacman"
        items.append(
            PackageItem(
                source=source,
                manager="pacman",
                name=name,
                package_id=name,
                version=version,
                installed=True,
            )
        )
    return items


