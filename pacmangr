def parse_generic_search(manager: str, output: str, installed_names: set[str]) -> list[PackageItem]:
    items: list[PackageItem] = []
    for raw_line in output.splitlines():
        line = raw_line.strip()
        if not line or line.startswith(("Loaded ", "Available ", "Last metadata", "Name ", "====")):
            continue
        name = ""
        version = ""
        description = ""
        if " - " in line:
            left, description = line.split(" - ", 1)
            name = left.split()[0]
        elif " : " in line:
            left, description = line.split(" : ", 1)
            name = left.split()[0].split(".")[0]
        elif "/" in line and manager == "zypper":
            parts = [part.strip() for part in line.split("|")]
            if len(parts) >= 3 and parts[1] and parts[1] != "Name":
                name = parts[1]
                version = parts[3] if len(parts) > 3 else ""
        else:
            parts = line.split()
            if parts:
                name = parts[0].lstrip("[-*>=~")
                if len(parts) > 1 and re.match(r"^[0-9][A-Za-z0-9_.:+~-]*$", parts[1]):
                    version = parts[1]
        name = name.strip("|,;:")
        if not name or name.lower() in {"name", "package", "installed", "available"}:
            continue
        items.append(
            PackageItem(
                source=manager,
                manager=manager,
                repo=manager,
                name=name,
                package_id=name,
                version=version,
                description=description.strip(),
                installed=name in installed_names,
            )
        )
    return items[:MAX_RESULTS]


def parse_generic_installed(manager: str, output: str) -> list[PackageItem]:
    items: list[PackageItem] = []
    for raw_line in output.splitlines():
        line = raw_line.strip()
        if not line or line.startswith(("Name ", "Installed", "Listing", "====")):
            continue
        if "|" in line and manager == "zypper":
            parts = [part.strip() for part in line.split("|")]
            if len(parts) >= 3 and parts[1] and parts[1] != "Name":
                items.append(
                    PackageItem(
                        source=manager,
                        manager=manager,
                        repo=manager,
                        name=parts[1],
                        package_id=parts[1],
                        version=parts[3] if len(parts) > 3 else "",
                        installed=True,
                    )
                )
            continue
        parts = line.split()
        if not parts:
            continue
        name = parts[0].lstrip("[-*>=~")
        version = ""
        if len(parts) > 1 and re.match(r"^[0-9][A-Za-z0-9_.:+~-]*$", parts[1]):
            version = parts[1].rstrip(":")
        if not name or name.lower() in {"name", "package"}:
            continue
        items.append(
            PackageItem(
                source=manager,
                manager=manager,
                repo=manager,
                name=name,
                package_id=name,
                version=version,
                installed=True,
            )
        )
    return items


def parse_manager_search(manager: str, output: str, installed_names: set[str]) -> list[PackageItem]:
    parser = MANAGER_SPECS.get(manager, {}).get("parser")
    if parser == "cargo":
        return parse_cargo_search(output, installed_names)
    if parser == "npm":
        return parse_npm_search(output, installed_names)
    if parser == "pip":
        return parse_pip_search(output, installed_names)
    return parse_generic_search(manager, output, installed_names)


def parse_manager_installed(manager: str, output: str) -> list[PackageItem]:
    parser = MANAGER_SPECS.get(manager, {}).get("parser")
    if parser == "cargo":
        return parse_cargo_installed(output)
    if parser == "npm":
        return parse_npm_installed(output)
    if parser == "pip":
        return parse_pip_installed(output)
    if parser == "pipx":
        return parse_pipx_installed(output)
    return parse_generic_installed(manager, output)


def appimage_roots() -> list[Path]:
    home = Path.home()
    return [
        home / "Applications",
        home / "Downloads",
        home / ".local" / "bin",
        home / ".local" / "share" / "AppImages",
        home / ".local" / "share" / "appimagekit",
        home / ".local" / "share" / "applications",
        Path("/opt"),
    ]


def find_appimages(query: str = "") -> list[PackageItem]:
    needle = query.lower().strip()
    seen: set[Path] = set()
    items: list[PackageItem] = []
    for root in appimage_roots():
        if not root.exists():
            continue
        root = root.resolve()
        for dirpath, dirnames, filenames in os.walk(root, followlinks=False):
            current = Path(dirpath)
            try:
                depth = len(current.relative_to(root).parts)
            except ValueError:
                depth = 0
            if depth >= APPIMAGE_SCAN_DEPTH:
                dirnames[:] = []
            for filename in filenames:
                if not filename.lower().endswith(".appimage"):
                    continue
                path = current / filename
                try:
                    resolved = path.resolve()
                except OSError:
                    resolved = path
                if resolved in seen:
                    continue
                haystack = f"{filename} {path}".lower()
                if needle and needle not in haystack:
                    continue
                seen.add(resolved)
                try:
                    size = path.stat().st_size
                except OSError:
                    size = 0
                items.append(
                    PackageItem(
                        source="appimage",
                        manager="appimage",
                        repo="local file",
                        name=path.stem,
                        package_id=str(path),
                        version=human_size(size),
                        description=f"Local AppImage: {path}",
                        installed=True,
                    )
                )
    return sorted(items, key=lambda item: item.name.lower())


def human_size(size: int) -> str:
    units = ["B", "KiB", "MiB", "GiB", "TiB"]
    value = float(size)
    for unit in units:
        if value < 1024 or unit == units[-1]:
            if unit == "B":
                return f"{int(value)} {unit}"
            return f"{value:.1f} {unit}"
        value /= 1024


