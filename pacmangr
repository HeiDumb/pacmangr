        name, version, status = parts[:3]
        if not status.startswith("ii"):
            continue
        description = parts[3].strip() if len(parts) > 3 else ""
        items.append(
            PackageItem(
                source="apt",
                manager="apt",
                repo="dpkg",
                name=name,
                package_id=name,
                version=version,
                description=description,
                installed=True,
